generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("User")
  createdAt DateTime @default(now())
}

model Lead {
  id           String   @id @default(cuid())
  email        String?
  phone        String?
  status       String   @default("New")
  createdAt    DateTime @default(now())
  category     String
  company      String?
  contactName  String
  serviceType  String
  assignedUser String?
}

model Activity {
  id            String   @id @default(cuid())
  title         String
  type          String
  date          DateTime
  time          String
  duration      Int
  description   String?
  salesperson   String?
  leadId        String?
  opportunityId String?
  done          Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ReferralPipeline {
  id                String            @id @default(cuid())
  name              String
  sequence          Int
  color             String?
  isFinal           Boolean           @default(false)
  createdAt         DateTime          @default(now())
  referrals         Referral[]
  referralHistories ReferralHistory[]
}

model Referral {
  id                String            @id @default(cuid())
  referralCode      String            @unique
  referrerId        String
  referrerName      String
  referrerCompany   String
  referredLeadName  String
  referredCompany   String
  referredEmail     String?
  referredPhone     String?
  rewardType        String
  rewardValue       Float
  rewardApproved    Boolean           @default(false)
  currentStageId    String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  currentStage      ReferralPipeline  @relation(fields: [currentStageId], references: [id])
  referralHistories ReferralHistory[]
  referralRewards   ReferralReward[]
}

model ReferralHistory {
  id         String           @id @default(cuid())
  referralId String
  stageId    String
  changedBy  String
  remarks    String?
  createdAt  DateTime         @default(now())
  referral   Referral         @relation(fields: [referralId], references: [id])
  pipeline   ReferralPipeline @relation(fields: [stageId], references: [id])
}

model ReferralReward {
  id         String    @id @default(cuid())
  referralId String
  amount     Float
  rewardType String
  approved   Boolean   @default(false)
  approvedBy String?
  paid       Boolean   @default(false)
  paidDate   DateTime?
  referral   Referral  @relation(fields: [referralId], references: [id])
}

model Opportunity {
  id                  String    @id @default(cuid())
  leadId              String?
  customerName        String
  company             String?
  email               String?
  phone               String?
  dealValue           Float
  stage               String    @default("New")
  stageId             String?
  assignedSalesperson String?
  expectedClosing     DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model Customer {
  id                  String   @id @default(cuid())
  opportunityId       String?
  customerName        String
  company             String?
  email               String?
  phone               String?
  dealValue           Float
  assignedSalesperson String?
  status              String   @default("Active")
  joinedAt            DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
